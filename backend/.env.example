# Copy to .env and adjust as needed
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/attendance_tracker
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
# Hour at/after which a check-in is considered "late" (24h local time)
LATE_THRESHOLD_HOUR=9
LATE_THRESHOLD_MINUTE=30
# Standard work day length in hours (used to cap a forgotten check-out)
STANDARD_DAY_HOURS=9
CLIENT_ORIGIN=http://localhost:5173
